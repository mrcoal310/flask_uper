# Flask base config
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# Device identity
APP_PRODUCT_ID=envctrl_v1
APP_DEVICE_ID=iot_node_001
APP_PROTO_VER=1.0

# MQTT broker config
MQTT_HOST= Your MQTT Host
MQTT_PORT=1883
MQTT_CLIENT_ID= Your Client Id
MQTT_USERNAME= Your Username
MQTT_PASSWORD= Your Password
MQTT_KEEPALIVE=30
MQTT_TLS=false
MQTT_BASE_TOPIC=

# Optional token-only MQTT authentication
API_TOKEN=

# Storage
SQLITE_PATH=instance/iot_upper_computer.db
